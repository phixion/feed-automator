{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "feed-automator",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html"
      },
      "settings": {
        "entry": "settings.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "Create a new post",
        "description": "feed-automator",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      },
      {
        "label": "Manage Feeds",
        "description": "Configure RSS feeds",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/settings"
      }
    ]
  },
  "forms": {
    "settings": "/internal/form/settings-submit"
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build"
  },
  "dev": {
    "subreddit": "feed_automator_dev"
  },
  "permissions": {
    "http": {
      "enable": true,
      "domains": [
        "www.tagesschau.de",
        "www.spiegel.de",
        "digitalegesellschaft.de",
        "digitalcourage.de",
        "noyb.eu",
        "www.ccc.de",
        "netzpolitik.org"
      ]
    }
  }
}