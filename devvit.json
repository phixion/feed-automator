{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "feed-automator",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "Create a new post",
        "description": "feed-automator",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      }
    ]
  },
  "settings": {
    "subreddit": {
      "rss_urls": {
        "type": "string",
        "label": "RSS Feed URLs (Comma seperated)",
        "default": "https://www.tagesschau.de/xml/rss2, https://feeds.heise.de/heise/newsticker"
      },
      "target_subreddit": {
        "type": "string",
        "label": "Target Subreddit",
        "default": "mein_test_sub"
      }
    }
  },
  "tasks": {
    "rss_fetch_job": {
      "endpoint": "/internal/tasks/rss-fetch",
      "cron": "*/10 * * * *"
    }
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build"
  },
  "dev": {
    "subreddit": "feed_automator_dev"
  },
  "permissions": {
    "http": {
      "enable": true,
      "domains": [
        "www.tagesschau.de",
        "www.spiegel.de",
        "digitalegesellschaft.de",
        "digitalcourage.de",
        "noyb.eu",
        "www.ccc.de",
        "netzpolitik.org"
      ]
    }
  }
}