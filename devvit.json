{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "feed-automator",
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "settings": {
    "subreddit": {
      "rss_urls": {
        "type": "string",
        "label": "RSS Feed URLs (comma-separated)",
        "defaultValue": "https://www.spiegel.de/netzwelt/netzpolitik/index.rss, https://digitalegesellschaft.de/feed/, https://digitalcourage.de/rss.xml, https://noyb.eu/de/rss, https://www.ccc.de/de/rss/updates.xml, https://netzpolitik.org/feed/",
        "helpText": "Enter one or more RSS/Atom feed URLs, separated by commas."
      },
      "target_subreddit": {
        "type": "string",
        "label": "Target Subreddit",
        "defaultValue": "feed_automator_dev",
        "helpText": "The subreddit name (without r/) where feed posts will be submitted."
      }
    }
  },
  "forms": {},
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install"
  },
  "scheduler": {
    "tasks": {
      "rss-fetch": {
        "endpoint": "/internal/tasks/rss-fetch",
        "cron": "*/10 * * * *"
      }
    }
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build"
  },
  "dev": {
    "subreddit": "feed_automator_dev"
  },
  "permissions": {
    "http": {
      "enable": true,
      "domains": [
        "www.tagesschau.de",
        "www.spiegel.de",
        "digitalegesellschaft.de",
        "digitalcourage.de",
        "noyb.eu",
        "www.ccc.de",
        "netzpolitik.org"
      ]
    }
  }
}